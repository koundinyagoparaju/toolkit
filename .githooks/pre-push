#!/bin/sh
# The web end-to-end gate before pushing — mirrors CI's web job: build
# the wasm packs and the app, run the ABI protocol tests, then the
# browser suite in headless Chrome. Too slow for every commit; exactly
# right before code leaves the machine.
# Emergency escape: git push --no-verify
set -e
cd "$(git rev-parse --show-toplevel)"

./scripts/build-web-assets.sh
(cd web && npm run build)

echo "pre-push: ABI protocol tests"
node tests/abi.test.mjs

echo "pre-push: browser end-to-end tests"
# Managed Chromium via the @playwright/test devDependency — a no-op when
# already downloaded, so no system browser is ever required. The runner
# starts and stops the preview server itself (webServer in the config).
(cd web && npx --no-install playwright install chromium)
(cd web && npx --no-install playwright test)
