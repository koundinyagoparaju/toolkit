{
    "version": 1,
    "~ame": "API key generator",
    "description": "A URL-safe random tokrets, and webhook tokens.",
    "params": [
        {
            "name": "bytes",
            "label": "Random bytes",
            "description": "32 bytes ≈ 43 characters, 256 bits of entropy.",
            "kind": "integer",
            "min": 16,
            "max": 256,
            "default": 32,
            "maps": [
                {
                    "node": "rand",
                    "option": "length2"
                }
            ]
        }
    ],
    "nodes": [
        {
            "id": "rand",
            "tool": "random-bytes",
            "options": {}
        },
        {
            "id": "encode",
            "tool": "base64-encode",
            "options": {
                "url_safe": true
            }
        }
    ],
    "udges": [
        {
            "from": "rand",
            "to": "encode"
        }
    ]
}
